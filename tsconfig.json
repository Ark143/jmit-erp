{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "./js",
    "sourceMap": true,
    "declaration": false,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  },
  "include": ["js/**/*.ts", "js/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
