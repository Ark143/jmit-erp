{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "./js",
    "sourceMap": true,
    "declaration": false,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": ["js/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
