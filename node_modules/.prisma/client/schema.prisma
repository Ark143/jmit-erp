generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Settings & Configuration ───

model Company {
  id       String @id
  name     String
  taxId    String
  address  String
  currency String @default("USD")
}

model AppSettings {
  id                    Int     @id @default(1)
  activeCompanyId       String?
  activeCurrency        String  @default("USD")
  skuPrefix             String  @default("JMIT-")
  skuSequence           Int     @default(1005)
  skuSuffix             String  @default("-HW")
  glCashAccount         String  @default("1010")
  glArAccount           String  @default("1200")
  glApAccount           String  @default("2010")
  glWhtAssetAccount     String  @default("1210")
  glInventoryAccount    String  @default("1300")
  glTaxAccount          String  @default("2200")
  glWhtLiabilityAccount String  @default("2220")
  glSalesAccount        String  @default("4100")
  glCogsAccount         String  @default("5100")
  glOpexAccount         String  @default("6010")
  glDeprExpenseAccount  String  @default("6100")
  glAccumDeprAccount    String  @default("1810")
}

model WorkflowRequirement {
  id                Int     @id @default(1)
  soApproval        Boolean @default(true)
  dnSubmission      Boolean @default(true)
  siSubmission      Boolean @default(true)
  poApproval        Boolean @default(true)
  grnSubmission     Boolean @default(true)
  piSubmission      Boolean @default(true)
  paymentSubmission Boolean @default(true)
  journalSubmission Boolean @default(true)
}

model FiscalPeriod {
  name   String  @id
  start  String
  end    String
  closed Boolean @default(false)
}

model ExchangeRate {
  currency String @id
  rate     Float
}

// ─── Auth & RBAC ───

model User {
  id       String @id
  username String @unique
  name     String
  roleId   String
  role     Role   @relation(fields: [roleId], references: [id])
}

model Role {
  id          String       @id
  name        String
  permissions Permission[]
  users       User[]
}

model Permission {
  id         String  @id @default(uuid())
  roleId     String
  module     String // o2c | p2p | inventory | accounting | finance | settings
  canRead    Boolean @default(false)
  canCreate  Boolean @default(false)
  canUpdate  Boolean @default(false)
  canDelete  Boolean @default(false)
  canApprove Boolean @default(false)
  role       Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
}

// ─── Business Partners ───

model Lead {
  id      String @id
  name    String
  contact String
  email   String
  phone   String
  address String
  status  String @default("Open")
}

model Customer {
  id          String       @id
  name        String
  contact     String
  email       String
  phone       String
  address     String
  taxId       String
  taxRate     Float        @default(0.12)
  whtRate     Float        @default(0.02)
  salesOrders SalesOrder[]
}

model Vendor {
  id             String          @id
  name           String
  contact        String
  email          String
  phone          String
  address        String
  taxId          String
  defaultTerms   String          @default("Net 30")
  purchaseOrders PurchaseOrder[]
}

// ─── Inventory ───

model Warehouse {
  id                String             @id
  name              String
  address           String
  stockLevels       StockLevel[]
  deliveryNotes     DeliveryNote[]
  goodsReceiptNotes GoodsReceiptNote[]
}

model Item {
  id          String       @id
  sku         String       @unique
  name        String
  category    String
  uom         String       @default("pcs")
  cost        Float        @default(0)
  price       Float        @default(0)
  reorder     Int          @default(5)
  stockLevels StockLevel[]
}

model StockLevel {
  id          String    @id @default(uuid())
  itemId      String
  warehouseId String
  qty         Int       @default(0)
  item        Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([itemId, warehouseId])
}

model UomConversion {
  id   String @id @default(uuid())
  from String
  to   String
  rate Float
}

// ─── Chart of Accounts ───

model Account {
  code       String  @id
  name       String
  type       String // Asset | Liability | Equity | Revenue | Expense
  parentCode String?
  balance    Float   @default(0)
}

// ─── Fixed Assets ───

model FixedAsset {
  id                String  @id
  name              String
  purchaseDate      String
  cost              Float
  usefulLife        Int
  salvageValue      Float   @default(0)
  accumDepreciation Float   @default(0)
  assetAccount      String  @default("1800")
  deprAccount       String  @default("1810")
  expenseAccount    String  @default("6100")
  active            Boolean @default(true)
}

// ─── O2C: Sales Orders → Deliveries → Invoices ───

model SalesOrder {
  id           String           @id
  companyId    String
  customerId   String
  customerName String
  date         String
  currency     String           @default("USD")
  rate         Float            @default(1.0)
  subtotal     Float            @default(0)
  tax          Float            @default(0)
  withholding  Float            @default(0)
  total        Float            @default(0)
  status       String           @default("Draft")
  lines        SalesOrderLine[]
  customer     Customer         @relation(fields: [customerId], references: [id])
}

model SalesOrderLine {
  id      String     @id @default(uuid())
  orderId String
  itemId  String
  sku     String
  name    String
  qty     Int
  price   Float
  uom     String     @default("pcs")
  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model DeliveryNote {
  id           String         @id
  salesOrderId String
  companyId    String
  customerId   String
  customerName String
  date         String
  warehouseId  String
  status       String         @default("Draft")
  lines        DeliveryLine[]
  warehouse    Warehouse      @relation(fields: [warehouseId], references: [id])
}

model DeliveryLine {
  id         String       @id @default(uuid())
  deliveryId String
  itemId     String
  sku        String
  qty        Int
  uom        String       @default("pcs")
  delivery   DeliveryNote @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

model SalesInvoice {
  id             String             @id
  salesOrderId   String
  deliveryNoteId String             @default("")
  companyId      String
  customerId     String
  customerName   String
  date           String
  subtotal       Float              @default(0)
  tax            Float              @default(0)
  withholding    Float              @default(0)
  total          Float              @default(0)
  status         String             @default("Draft")
  lines          SalesInvoiceLine[]
}

model SalesInvoiceLine {
  id        String       @id @default(uuid())
  invoiceId String
  itemId    String
  sku       String
  name      String
  qty       Int
  price     Float
  uom       String       @default("pcs")
  invoice   SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model SalesReturn {
  id             String            @id
  salesInvoiceId String
  customerId     String
  customerName   String
  date           String
  totalReturn    Float
  status         String            @default("Submitted")
  lines          SalesReturnLine[]
}

model SalesReturnLine {
  id          String      @id @default(uuid())
  returnId    String
  itemId      String
  qty         Int
  uom         String      @default("pcs")
  salesReturn SalesReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
}

// ─── P2P: Purchase Orders → GRNs → Invoices ───

model PurchaseOrder {
  id         String              @id
  companyId  String
  vendorId   String
  vendorName String
  date       String
  currency   String              @default("USD")
  rate       Float               @default(1.0)
  total      Float               @default(0)
  status     String              @default("Draft")
  lines      PurchaseOrderLine[]
  vendor     Vendor              @relation(fields: [vendorId], references: [id])
}

model PurchaseOrderLine {
  id      String        @id @default(uuid())
  orderId String
  itemId  String
  sku     String
  name    String
  qty     Int
  cost    Float
  uom     String        @default("pcs")
  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model GoodsReceiptNote {
  id              String             @id
  purchaseOrderId String
  companyId       String
  vendorId        String
  vendorName      String
  date            String
  warehouseId     String
  status          String             @default("Draft")
  lines           GoodsReceiptLine[]
  warehouse       Warehouse          @relation(fields: [warehouseId], references: [id])
}

model GoodsReceiptLine {
  id          String           @id @default(uuid())
  grnId       String
  itemId      String
  acceptedQty Int
  rejectedQty Int              @default(0)
  uom         String           @default("pcs")
  grn         GoodsReceiptNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
}

model PurchaseInvoice {
  id              String                @id
  purchaseOrderId String
  goodsReceiptId  String                @default("")
  companyId       String
  vendorId        String
  vendorName      String
  date            String
  total           Float                 @default(0)
  status          String                @default("Draft")
  lines           PurchaseInvoiceLine[]
}

model PurchaseInvoiceLine {
  id        String          @id @default(uuid())
  invoiceId String
  itemId    String
  sku       String
  name      String
  qty       Int
  cost      Float
  uom       String          @default("pcs")
  invoice   PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model PurchaseReturn {
  id                String               @id
  purchaseInvoiceId String
  vendorId          String
  vendorName        String
  date              String
  totalReturn       Float
  status            String               @default("Submitted")
  lines             PurchaseReturnLine[]
}

model PurchaseReturnLine {
  id             String         @id @default(uuid())
  returnId       String
  itemId         String
  qty            Int
  uom            String         @default("pcs")
  purchaseReturn PurchaseReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
}

// ─── Treasury ───

model Payment {
  id                 String @id
  type               String // Receive | Pay
  companyId          String
  partnerId          String
  partnerName        String
  referenceInvoiceId String @default("")
  reference          String
  date               String
  amount             Float
  currency           String @default("USD")
  rate               Float  @default(1.0)
  status             String @default("Draft")
}

// ─── Stock Movements ───

model StockEntry {
  id                String           @id
  type              String // Receipt | Issue | Transfer
  date              String
  sourceWarehouseId String           @default("")
  targetWarehouseId String           @default("")
  reason            String
  status            String           @default("Draft")
  lines             StockEntryLine[]
}

model StockEntryLine {
  id          String     @id @default(uuid())
  entryId     String
  itemId      String
  qty         Int        @default(0)
  acceptedQty Int        @default(0)
  rejectedQty Int        @default(0)
  uom         String     @default("pcs")
  entry       StockEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

// ─── General Ledger ───

model JournalEntry {
  id        String             @id
  date      String
  reference String
  companyId String
  status    String             @default("Draft")
  lines     JournalEntryLine[]
}

model JournalEntryLine {
  id      String       @id @default(uuid())
  entryId String
  code    String
  debit   Float        @default(0)
  credit  Float        @default(0)
  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
}
